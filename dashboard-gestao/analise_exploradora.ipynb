# 📦 1. Importação de Bibliotecas

# Manipulação de dados
import pandas as pd
import numpy as np
from pathlib import Path
from datetime import datetime

# Visualização
import matplotlib.pyplot as plt
import seaborn as sns
import plotly.express as px
import plotly.graph_objects as go

# Machine Learning
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

# Streamlit
import streamlit as st

# Configurações
import warnings
warnings.filterwarnings('ignore')

# Configuração de visualização
plt.style.use('seaborn-v0_8-darkgrid')
sns.set_palette('husl')
%matplotlib inline

print('✅ Bibliotecas importadas com sucesso!')

# ---
# 📂 2. Configuração de Caminhos

# Definir caminhos dos diretórios
SISTEMA = Path(r"D:\Meu Drive\Trabalho\Floresta_cast\ADM\P&D&I\Sistema")
DADOS_CC = Path(r"D:\Meu Drive\Trabalho\Bracell\Relatorios\Boletins\CC")
DADOS_PLANEJAMENTO = Path(r"D:\Meu Drive\Trabalho\Bracell\Relatorios\Planejamento")
SAIDA_DASHBOARD = Path(r"D:\Meu Drive\Trabalho\Floresta_cast\ADM\P&D&I\Dashboard")

print(f"📁 Diretório CC existe: {DADOS_CC.exists()}")
print(f"📁 Diretório Planejamento existe: {DADOS_PLANEJAMENTO.exists()}")
print(f"📁 Diretório Dashboard existe: {SAIDA_DASHBOARD.exists()}")

# ---
# 📊 3. Carregamento de Dados
#
# ### 3.1 Boletins de Consulta Completa (CC)

# Carregar todos os arquivos CC*.xlsx
arquivos_cc = list(DADOS_CC.glob("CC*.xlsx"))
print(f"📋 Arquivos CC encontrados: {len(arquivos_cc)}")

if arquivos_cc:
    dataframes_cc = []
    for arquivo in arquivos_cc:
        df_temp = pd.read_excel(arquivo)
        df_temp['arquivo_origem'] = arquivo.name
        dataframes_cc.append(df_temp)
        print(f"  ✓ {arquivo.name}: {len(df_temp)} registros")
    
    df_boletins = pd.concat(dataframes_cc, ignore_index=True)
    print(f"\n✅ Total de registros: {len(df_boletins):,}")
    print(f"📐 Dimensões: {df_boletins.shape}")
else:
    print("⚠️ Nenhum arquivo CC encontrado")
    df_boletins = None

# ### 3.2 Plano Anual de Silvicultura (PAS)

# Carregar PAS.xlsx
arquivo_pas = DADOS_PLANEJAMENTO / "PAS.xlsx"

if arquivo_pas.exists():
    df_pas = pd.read_excel(arquivo_pas)
    print(f"✅ PAS.xlsx carregado")
    print(f"📐 Dimensões: {df_pas.shape}")
    print(f"📋 Colunas: {len(df_pas.columns)}")
else:
    print(f"⚠️ Arquivo não encontrado: {arquivo_pas}")
    df_pas = None

# ---
# 🔍 4. Análise Exploratória de Dados
#
# ### 4.1 Visão Geral - Boletins

if df_boletins is not None:
    print("📊 RESUMO DOS DADOS - BOLETINS")
    print("=" * 60)
    display(df_boletins.head())
    print("\n📋 Informações das Colunas:")
    display(df_boletins.info())
    print("\n📈 Estatísticas Descritivas:")
    display(df_boletins.describe())

# ### 4.2 Valores Ausentes

if df_boletins is not None:
    # Analisar valores ausentes
    valores_ausentes = df_boletins.isnull().sum()
    percentual_ausentes = (valores_ausentes / len(df_boletins)) * 100
    
    df_ausentes = pd.DataFrame({
        'Coluna': valores_ausentes.index,
        'Valores Ausentes': valores_ausentes.values,
        'Percentual (%)': percentual_ausentes.values
    }).sort_values('Valores Ausentes', ascending=False)
    
    df_ausentes_filtrado = df_ausentes[df_ausentes['Valores Ausentes'] > 0]
    
    if len(df_ausentes_filtrado) > 0:
        print(f"⚠️ Colunas com valores ausentes: {len(df_ausentes_filtrado)}")
        display(df_ausentes_filtrado.head(20))
        
        # Visualizar
        plt.figure(figsize=(12, 6))
        top_20 = df_ausentes_filtrado.head(20)
        plt.barh(top_20['Coluna'], top_20['Percentual (%)'])
        plt.xlabel('Percentual de Valores Ausentes (%)')
        plt.title('Top 20 Colunas com Valores Ausentes')
        plt.tight_layout()
        plt.show()
    else:
        print("✅ Nenhum valor ausente encontrado!")

# ### 4.3 Visão Geral - PAS

if df_pas is not None:
    print("📊 RESUMO DOS DADOS - PLANO ANUAL SILVICULTURA")
    print("=" * 60)
    display(df_pas.head())
    print("\n📋 Colunas disponíveis:")
    print(df_pas.columns.tolist())
    print("\n📈 Estatísticas Descritivas (Colunas Numéricas):")
    display(df_pas.describe())

# ---
# 📈 5. Visualizações
#
# ### 5.1 Análise de Produtividade (IMA6)

if df_pas is not None and 'IMA6' in df_pas.columns:
    # Remover valores nulos para análise
    df_ima6 = df_pas.dropna(subset=['IMA6'])
    
    fig, axes = plt.subplots(1, 2, figsize=(15, 5))
    
    # Histograma
    axes[0].hist(df_ima6['IMA6'], bins=30, edgecolor='black', alpha=0.7)
    axes[0].set_xlabel('IMA6 (m³/ha/ano)')
    axes[0].set_ylabel('Frequência')
    axes[0].set_title('Distribuição de IMA6')
    axes[0].axvline(df_ima6['IMA6'].mean(), color='red', linestyle='--', label=f'Média: {df_ima6["IMA6"].mean():.2f}')
    axes[0].legend()
    
    # Boxplot
    axes[1].boxplot(df_ima6['IMA6'], vert=True)
    axes[1].set_ylabel('IMA6 (m³/ha/ano)')
    axes[1].set_title('Boxplot de IMA6')
    
    plt.tight_layout()
    plt.show()
    
    print(f"\n📊 Estatísticas IMA6:")
    print(f"   Média: {df_ima6['IMA6'].mean():.2f} m³/ha/ano")
    print(f"   Mediana: {df_ima6['IMA6'].median():.2f} m³/ha/ano")
    print(f"   Desvio Padrão: {df_ima6['IMA6'].std():.2f} m³/ha/ano")
    print(f"   Mínimo: {df_ima6['IMA6'].min():.2f} m³/ha/ano")
    print(f"   Máximo: {df_ima6['IMA6'].max():.2f} m³/ha/ano")

# ### 5.2 Análise por Regional

if df_pas is not None and 'REGIONAL' in df_pas.columns and 'IMA6' in df_pas.columns:
    df_regional = df_pas.groupby('REGIONAL')['IMA6'].agg(['mean', 'count', 'std']).reset_index()
    df_regional.columns = ['REGIONAL', 'IMA6_Medio', 'Quantidade', 'Desvio_Padrao']
    df_regional = df_regional.sort_values('IMA6_Medio', ascending=False)
    
    # Gráfico interativo com Plotly
    fig = px.bar(df_regional, 
                 x='REGIONAL', 
                 y='IMA6_Medio',
                 title='IMA6 Médio por Regional',
                 labels={'IMA6_Medio': 'IMA6 Médio (m³/ha/ano)', 'REGIONAL': 'Regional'},
                 text='IMA6_Medio',
                 color='IMA6_Medio',
                 color_continuous_scale='Viridis')
    
    fig.update_traces(texttemplate='%{text:.2f}', textposition='outside')
    fig.update_layout(height=500)
    fig.show()
    
    display(df_regional)

# ### 5.3 Análise por Material Genético

if df_pas is not None and 'MATERIAL_GENETICO' in df_pas.columns and 'IMA6' in df_pas.columns:
    df_mg = df_pas.groupby('MATERIAL_GENETICO')['IMA6'].agg(['mean', 'count']).reset_index()
    df_mg.columns = ['Material_Genetico', 'IMA6_Medio', 'Quantidade']
    df_mg = df_mg.sort_values('IMA6_Medio', ascending=False).head(15)
    
    fig = px.scatter(df_mg, 
                     x='Quantidade', 
                     y='IMA6_Medio',
                     size='Quantidade',
                     hover_data=['Material_Genetico'],
                     title='IMA6 Médio vs Quantidade por Material Genético (Top 15)',
                     labels={'IMA6_Medio': 'IMA6 Médio (m³/ha/ano)', 'Quantidade': 'Quantidade de Registros'})
    
    fig.show()

# ---
# 🤖 6. Preparação para Machine Learning
#
# ### 6.1 Seleção de Features e Target

# Exemplo: Prever IMA6 com base em outras variáveis
if df_pas is not None and 'IMA6' in df_pas.columns:
    # Definir features e target (ajustar conforme necessidade)
    features_interesse = ['AREA', 'ROTACAO', 'PRECIPITACAO', 'SOBREVIVENCIA', 'IMA6_Expectativa']
    features_disponiveis = [col for col in features_interesse if col in df_pas.columns]
    
    print(f"📋 Features disponíveis para ML: {features_disponiveis}")
    
    if len(features_disponiveis) > 0:
        # Filtrar dados sem valores nulos na target e features
        df_ml = df_pas[features_disponiveis + ['IMA6']].dropna()
        
        # Separar em conjuntos de treino e teste
        X_train, X_test, y_train, y_test = train_test_split(df_ml[features_disponiveis], df_ml['IMA6'], test_size=0.2, random_state=42)
        
        # Padronizar os dados
        scaler = StandardScaler()
        X_train_scaled = scaler.fit_transform(X_train)
        X_test_scaled = scaler.transform(X_test)
        
        # Modelos de exemplo
        modelos = {
            'RandomForest': RandomForestRegressor(n_estimators=100, random_state=42),
            'GradientBoosting': GradientBoostingRegressor(n_estimators=100, random_state=42)
        }
        
        for nome, modelo in modelos.items():
            # Treinar o modelo
            modelo.fit(X_train_scaled, y_train)
            
            # Fazer previsões
            y_pred = modelo.predict(X_test_scaled)
            
            # Avaliar performance
            mae = mean_absolute_error(y_test, y_pred)
            mse = mean_squared_error(y_test, y_pred)
            r2 = r2_score(y_test, y_pred)
            
            print(f"🏆 {nome} - Performance do Modelo")
            print(f"  MAE: {mae:.2f}")
            print(f"  MSE: {mse:.2f}")
            print(f"  R²: {r2:.2f}")
            print("=" * 30)

